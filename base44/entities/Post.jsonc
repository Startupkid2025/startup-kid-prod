{
  "name": "Post",
  "type": "object",
  "properties": {
    "author_email": { "type": "string" },
    "author_name": { "type": "string" },
    "content": { "type": "string" },
    "likes": { "type": "array", "items": { "type": "string" } },
    "comments": { "type": "array", "items": { "type": "object" } },
    "created_date": { "type": "string" },
    "edited": { "type": "boolean", "default": false }
  }
}
